name: alina_be
services:
  certbot:
    container_name: alina_certbot
    depends_on:
      nginx:
        condition: service_started
        required: true
    image: certbot/certbot:latest
    networks:
      default: null
    volumes:
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/etc/nginx/fastcgi.conf
        target: /etc/nginx/fastcgi.conf
        read_only: true
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/etc/nginx/nginx.conf
        target: /etc/nginx/nginx.conf
        read_only: true
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/etc/nginx/conf.d
        target: /etc/nginx/conf.d
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/etc/letsencrypt
        target: /etc/letsencrypt
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/srv/sewa
        target: /srv/sewa
        read_only: true
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/log/nginx
        target: /var/log/nginx
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/log/letsencrypt
        target: /var/log/letsencrypt
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/www
        target: /var/www
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/www/certbot
        target: /var/www/certbot
        bind: {}
  mysql:
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - SETUID
      - SETGID
    cap_drop:
      - ALL
    command:
      - --innodb-buffer-pool-size=1G
      - --innodb-log-file-size=512M
      - --innodb-flush-log-at-trx-commit=2
      - --max-allowed-packet=64M
      - --skip-log-bin
      - --skip-name-resolve
      - --table-open-cache=2000
      - --tmp-table-size=64M
      - --max-heap-table-size=64M
      - --innodb-flush-neighbors=0
      - --performance-schema=ON
      - --log-error=/var/log/mysql/error.log
      - --slow-query-log=1
      - --slow-query-log-file=/var/log/mysql/slow.log
      - --long-query-time=2
      - --tls-version=TLSv1.2,TLSv1.3
      - --max-execution-time=30000
      - --connect-timeout=30
      - --net-read-timeout=60
      - --net-write-timeout=60
      - --max-connections=100
    container_name: alina_mysql
    deploy:
      resources:
        limits:
          cpus: 2
          memory: "2147483648"
    environment:
      CREATOR: VSEVOLOD_AZOVSKY
      MYSQL_DATABASE: borg_db
      MYSQL_HOST_1: mysql
      MYSQL_PASSWORD: new_borg_password_!@1234
      MYSQL_ROOT_PASSWORD: NewDbPassword@1234567890
      MYSQL_USER: borg_user
      PMA_ARBITRARY: "1"
      PMA_HOST: mysql
      PMA_PORT: "3306"
      TZ: Europe/Moscow
    expose:
      - "3306"
    healthcheck:
      test:
        - CMD
        - mysqladmin
        - ping
        - -h
        - localhost
        - -u
        - root
        - -p$$MYSQL_ROOT_PASSWORD
      timeout: 20s
      interval: 10s
      retries: 10
      start_period: 40s
    image: mysql:8.0.27
    init: true
    networks:
      default: null
    ports:
      - mode: ingress
        target: 3306
        published: "53306"
        protocol: tcp
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    tmpfs:
      - /var/run/mysqld
    volumes:
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/database/mysql
        target: /var/lib/mysql
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/database/mysql-tmp
        target: /tmp
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/log/mysql
        target: /var/log/mysql
        bind: {}
  nginx:
    build:
      context: /home/qqq/_A001/rep/ALINA_BE/docker/nginx
      dockerfile: Dockerfile
    cap_add:
      - NET_BIND_SERVICE
      - CHOWN
      - DAC_OVERRIDE
      - SETUID
      - SETGID
      - FOWNER
      - KILL
    cap_drop:
      - ALL
    command:
      - nginx
      - -g
      - daemon off;
    container_name: alina_nginx
    depends_on:
      php:
        condition: service_started
        required: true
    environment:
      CREATOR: VSEVOLOD_AZOVSKY
      MYSQL_DATABASE: borg_db
      MYSQL_HOST_1: mysql
      MYSQL_PASSWORD: new_borg_password_!@1234
      MYSQL_ROOT_PASSWORD: NewDbPassword@1234567890
      MYSQL_USER: borg_user
      PMA_ARBITRARY: "1"
      PMA_HOST: mysql
      PMA_PORT: "3306"
      TZ: Europe/Moscow
    links:
      - php
    networks:
      default: null
    ports:
      - mode: ingress
        target: 80
        published: "50080"
        protocol: tcp
      - mode: ingress
        target: 443
        published: "50443"
        protocol: tcp
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    volumes:
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/etc/nginx/fastcgi.conf
        target: /etc/nginx/fastcgi.conf
        read_only: true
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/etc/nginx/nginx.conf
        target: /etc/nginx/nginx.conf
        read_only: true
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/etc/nginx/conf.d
        target: /etc/nginx/conf.d
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/etc/letsencrypt
        target: /etc/letsencrypt
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/srv/sewa
        target: /srv/sewa
        read_only: true
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/log/nginx
        target: /var/log/nginx
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/log/letsencrypt
        target: /var/log/letsencrypt
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/www
        target: /var/www
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/www/certbot
        target: /var/www/certbot
        bind: {}
  php:
    build:
      context: /home/qqq/_A001/rep/ALINA_BE/docker/php
      dockerfile: Dockerfile
      args:
        INSTALL_XDEBUG: "true"
    cap_add:
      - SETUID
      - SETGID
    cap_drop:
      - ALL
    container_name: alina_php
    depends_on:
      mysql:
        condition: service_healthy
        required: true
    environment:
      CREATOR: VSEVOLOD_AZOVSKY
      MYSQL_DATABASE: borg_db
      MYSQL_HOST_1: mysql
      MYSQL_PASSWORD: new_borg_password_!@1234
      MYSQL_ROOT_PASSWORD: NewDbPassword@1234567890
      MYSQL_USER: borg_user
      PMA_ARBITRARY: "1"
      PMA_HOST: mysql
      PMA_PORT: "3306"
      TZ: Europe/Moscow
      XDEBUG_CLIENT_HOST: host.docker.internal
      XDEBUG_CLIENT_PORT: "9003"
      XDEBUG_MODE: develop
      XDEBUG_START_WITH_REQUEST: "yes"
    expose:
      - "9000"
      - "9001"
    extra_hosts:
      - host.docker.internal=host-gateway
    links:
      - mysql
    networks:
      default: null
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    tmpfs:
      - /tmp
    volumes:
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/usr/local/etc/php/php.ini
        target: /usr/local/etc/php/php.ini
        read_only: true
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/log/php
        target: /var/log/php
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/www
        target: /var/www
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/srv
        target: /srv
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/usr/local/etc/php/conf.d
        target: /usr/local/etc/php/conf.d
        read_only: true
        bind: {}
    working_dir: /srv/alina
  php-cs-fixer:
    container_name: alina_php_cs_fixer
    image: ghcr.io/php-cs-fixer/php-cs-fixer:3-php8.2
    networks:
      default: null
    read_only: true
    tmpfs:
      - /tmp
    user: "33:33"
    volumes:
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/var/www
        target: /apps/server/var/www
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/server/srv
        target: /apps/server/srv
        bind: {}
      - type: bind
        source: /home/qqq/_A001/rep/ALINA_BE/.php-cs-fixer.dist.php
        target: /apps/.php-cs-fixer.dist.php
        read_only: true
        bind: {}
    working_dir: /apps
networks:
  default:
    name: alina_be_default
x-vol-nginx:
  - ./server/etc/nginx/fastcgi.conf:/etc/nginx/fastcgi.conf:ro
  - ./server/etc/nginx/nginx.conf:/etc/nginx/nginx.conf:ro
  - ./server/etc/nginx/conf.d/:/etc/nginx/conf.d/:rw
  - ./server/etc/letsencrypt/:/etc/letsencrypt/
  - ./server/srv/sewa/:/srv/sewa/:ro
  - ./server/var/log/nginx/:/var/log/nginx/:rw
  - ./server/var/log/letsencrypt/:/var/log/letsencrypt/:rw
  - ./server/var/www/:/var/www/:rw
  - ./server/var/www/certbot/:/var/www/certbot/:rw
