#!/bin/bash

echo "=== Starting power management configuration ==="
echo "This script will:"
echo "1. Set power profile to 'performance'"
echo "2. Configure CPU governor for maximum performance"
echo "3. Disable USB autosuspend"
echo "4. Make settings persistent across reboots"
echo ""

# Step 1: Ensure power-profiles-daemon is enabled
echo "[Step 1/6] Enabling power-profiles-daemon..."
sudo systemctl enable power-profiles-daemon 2>/dev/null || echo "power-profiles-daemon already enabled"


# Set performance profile and mask auto‑switch
sudo powerprofilesctl set performance
sudo systemctl mask power-profile-switch.service 2>/dev/null
echo "Power profile set to 'performance'"

# Verify
current_profile=$(powerprofilesctl get)
echo "Current power profile: $current_profile"

# Step 2: Configure intel_pstate via GRUB
echo "[Step 2/6] Configuring GRUB for intel_pstate=performance..."
if grep -q "intel_pstate=performance" /etc/default/grub; then
    echo "intel_pstate=performance already in GRUB"
else
    sudo sed -i 's/GRUB_CMDLINE_LINUX="\(.*\)"/GRUB_CMDLINE_LINUX="\1 intel_pstate=performance"/' /etc/default/grub
    echo "Added intel_pstate=performance to GRUB"
fi

# Update GRUB
sudo update-grub
echo "GRUB updated"

# Step 3: Create UDev rule for USB autosuspend
echo "[Step 3/6] Creating UDev rule to disable USB autosuspend..."
USB_RULE_FILE="/etc/udev/rules.d/50-usb-power-save.rules"
echo 'ACTION=="add", SUBSYSTEM=="usb", TEST=="power/control", ATTR{power/control}="on"' | sudo tee "$USB_RULE_FILE" > /dev/null
echo "UDev rule created: $USB_RULE_FILE"

# Reload UDev rules
sudo udevadm control --reload-rules
sudo udevadm trigger
echo "UDev rules reloaded"

# Step 4: Manually disable USB autosuspend for all devices
echo "[Step 4/6] Disabling USB autosuspend manually for all devices..."
for device in /sys/bus/usb/devices/*/power/control; do
    if [ -f "$device" ]; then
        echo on | sudo tee "$device" > /dev/null
    fi
done
echo "USB autosuspend disabled for all connected devices"

# Step 5: Set CPU governor to performance
echo "[Step 5/6] Setting CPU governor to 'performance'..."
for governor_file in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    if [ -f "$governor_file" ]; then
        echo performance | sudo tee "$governor_file" > /dev/null
    fi
done

# Verify CPU governor
current_governor=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null)
echo "Current CPU governor: $current_governor"

# Step 6: Create startup script for fallback
echo "[Step 6/6] Creating startup script for persistence..."
STARTUP_SCRIPT="/home/$USER/set-performance.sh"
cat << 'EOF' | sudo tee "$STARTUP_SCRIPT" > /dev/null
#!/bin/bash
powerprofilesctl set performance
for governor_file in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    if [ -f "$governor_file" ]; then
        echo performance | sudo tee "$governor_file" > /dev/null
    fi
done
for device in /sys/bus/usb/devices/*/power/control; do
    if [ -f "$device" ]; then
        echo on | sudo tee "$device" > /dev/null
    fi
done
EOF

sudo chmod +x "$STARTUP_SCRIPT"
echo "Startup script created: $STARTUP_SCRIPT"

# Add to KDE Autostart (if KDE is detected)
if [ -d "$HOME/.config/autostart" ]; then
    AUTOSTART_FILE="$HOME/.config/autostart/set-performance.desktop"
    cat << EOF | tee "$AUTOSTART_FILE" > /dev/null
[Desktop Entry]
Type=Application
Name=Set Performance Mode
Exec=$STARTUP_SCRIPT
Hidden=false
NoDisplay=false
X-GNOME-Autostart-Delay=10
EOF
    echo "Added to KDE Autostart: $AUTOSTART_FILE"
fi

# Final verification
echo ""
echo "=== Final Verification ==="
echo "Current power profile: $(powerprofilesctl get)"
echo "CPU governor: $(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null)"
echo "Checking USB autosuspend status..."
sudo dmesg | grep -i usb | tail -5

echo ""
echo "=== Configuration completed! ==="
echo "Please reboot your system and run this script again after reboot to verify persistence."
echo "After reboot, share the script output with me for analysis."
