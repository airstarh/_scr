#!/bin/bash
cd /osa/home/qqq/qemu

qemu-system-x86_64 \
  -machine pc \
  -cpu qemu64 \
  -smp 1 \
  -m 4096 \
  -drive file=w7x64_HDA.img,format=qcow2,if=ide \
  -drive file=/home/qqq/Downloads/virtio-win-0.1.190.iso,index=1,media=cdrom \
  -boot order=c \
  -vga std \
  -display gtk \
  -usb \
  -device usb-tablet \
  -rtc base=localtime \
  -audiodev pa,id=snd \
  -device ac97,audiodev=snd \
  -netdev user,id=net0 -device rtl8139,netdev=net0