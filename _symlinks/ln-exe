#!/bin/bash

# Step 1. Remove conflicting services
sudo rm -f /etc/init.d/cpufrequtils /etc/init.d/loadcpufreq
sudo rm -f /etc/systemd/system/cpufrequtils.service /etc/systemd/system/loadcpufreq.service

# Step 2. Reload systemd
sudo systemctl daemon-reload

# Step 3. Create the CPU governor service
cat << 'EOF' | sudo tee /etc/systemd/system/set-cpu-performance.service
[Unit]
Description=Set CPU governor to performance
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/bin/sh -c 'for governor_file in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do echo performance | tee "$governor_file"; done'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOFа

# Step 4. Apply the service
sudo systemctl daemon-reload
sudo systemctl enable --now set-cpu-performance.service

# Step 5. Ensure GRUB has the correct kernel parameter
sudo sed -i 's/GRUB_CMDLINE_LINUX="\(.*\)"/GRUB_CMDLINE_LINUX="\1 intel_pstate=performance"/' /etc/default/grub
sudo update-grub

# Step 6. Final verification
echo "=== FINAL VERIFICATION ==="
echo "CPU governor status:"
for governor_file in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    echo "  $governor_file: $(cat "$governor_file")"
done
echo "Service status:"
sudo systemctl status set-cpu-performance.service --no-pager
