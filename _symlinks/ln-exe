#!/bin/bash

echo "========================================="
echo "ZoneMinder Docker Diagnostic Tool"
echo "========================================="
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if containers are running
echo "1. Checking container status..."
if docker ps | grep -q zoneminder; then
    echo -e "${GREEN}✓ ZoneMinder container is running${NC}"
else
    echo -e "${RED}✗ ZoneMinder container is NOT running${NC}"
    echo "  Start it with: docker-compose up -d"
fi

if docker ps | grep -q zoneminder-mysql; then
    echo -e "${GREEN}✓ MySQL container is running${NC}"
else
    echo -e "${RED}✗ MySQL container is NOT running${NC}"
fi
echo ""

# Check shared memory
echo "2. Shared Memory (shm) size and usage..."
docker exec zoneminder df -h /dev/shm 2>/dev/null || echo -e "${RED}Cannot access container${NC}"
echo ""

# Check zmc processes
echo "3. Capture processes (zmc) status..."
ZMC_COUNT=$(docker exec zoneminder ps aux | grep -c "zmc -m" 2>/dev/null)
if [ "$ZMC_COUNT" -gt 0 ]; then
    echo -e "${GREEN}✓ Found $ZMC_COUNT zmc process(es):${NC}"
    docker exec zoneminder ps aux | grep "zmc -m" | grep -v grep
else
    echo -e "${RED}✗ No zmc processes found${NC}"
fi
echo ""

# Check zmc stability (looking for restarts in last 5 minutes)
echo "4. Checking zmc stability (restarts in last 5 minutes)..."
if [ -f ./data/logs/zmdc.log ]; then
    RECENT_RESTARTS=$(tail -500 ./data/logs/zmdc.log 2>/dev/null | grep -c "!send_stop so starting 'zmc" || echo "0")
    if [ "$RECENT_RESTARTS" -gt 0 ]; then
        echo -e "${RED}✗ Found $RECENT_RESTARTS zmc restarts in recent logs${NC}"
        echo "  Last 3 restart times:"
        tail -500 ./data/logs/zmdc.log | grep "!send_stop so starting 'zmc" | tail -3
    else
        echo -e "${GREEN}✓ No recent zmc restarts detected${NC}"
    fi
else
    echo -e "${YELLOW}⚠ Log file not found at ./data/logs/zmdc.log${NC}"
fi
echo ""

# Check database connectivity
echo "5. Database connectivity test..."
if docker exec zoneminder mysql -h mysql -u zmuser -pzmpass -e "SELECT 1 as test;" 2>/dev/null | grep -q 1; then
    echo -e "${GREEN}✓ Database connection successful${NC}"
else
    echo -e "${RED}✗ Database connection FAILED${NC}"
    echo "  Attempting to diagnose..."
    docker exec zoneminder mysql -h mysql -u zmuser -pzmpass -e "SELECT 1;" 2>&1 | head -3
fi
echo ""

# Check PATH_ZMS configuration
echo "6. Checking ZM_PATH_ZMS configuration..."
PATH_ZMS=$(docker exec zoneminder mysql -u zmuser -pzmpass zm -e "SELECT Value FROM Config WHERE Name='ZM_PATH_ZMS';" 2>/dev/null | tail -1)
if [ -n "$PATH_ZMS" ]; then
    echo -e "${GREEN}✓ ZM_PATH_ZMS = $PATH_ZMS${NC}"
else
    echo -e "${RED}✗ Could not retrieve ZM_PATH_ZMS${NC}"
fi
echo ""

# Check if zms binary exists
echo "7. Checking zms binary..."
if docker exec zoneminder test -f /usr/lib/zoneminder/cgi-bin/zms; then
    echo -e "${GREEN}✓ zms binary exists${NC}"
    docker exec zoneminder ls -la /usr/lib/zoneminder/cgi-bin/zms 2>/dev/null
else
    echo -e "${RED}✗ zms binary NOT found${NC}"
fi

if docker exec zoneminder test -f /usr/lib/zoneminder/cgi-bin/nph-zms; then
    echo -e "${GREEN}✓ nph-zms binary exists${NC}"
else
    echo -e "${RED}✗ nph-zms binary NOT found${NC}"
fi
echo ""

# Check Apache CGI
echo "8. Apache CGI module status..."
docker exec zoneminder apache2ctl -M 2>/dev/null | grep -q cgi
if [ $? -eq 0 ]; then
    echo -e "${GREEN}✓ CGI module is enabled${NC}"
else
    echo -e "${RED}✗ CGI module is NOT enabled${NC}"
    echo "  Fix with: docker exec zoneminder a2enmod cgi"
fi
echo ""

# Check socket directory
echo "9. Socket directory (/run/zm) status..."
docker exec zoneminder ls -la /run/zm/ 2>/dev/null
SOCKET_COUNT=$(docker exec zoneminder ls -la /run/zm/*.sock 2>/dev/null | wc -l)
if [ "$SOCKET_COUNT" -gt 0 ]; then
    echo -e "${GREEN}✓ Found $SOCKET_COUNT socket file(s)${NC}"
else
    echo -e "${YELLOW}⚠ No socket files found (normal if no streams are being viewed)${NC}"
fi
echo ""

# Check recent errors
echo "10. Recent errors from logs (last 20 lines)..."
echo "--- zmdc.log ---"
tail -20 ./data/logs/zmdc.log 2>/dev/null | grep -E "ERR|WAR" | tail -5 || echo "No errors found"
echo ""
echo "--- zmc_m1.log ---"
tail -20 ./data/logs/zmc_m1.log 2>/dev/null | grep -E "ERR|FATAL" | tail -5 || echo "No errors found"
echo ""

# Check docker-compose.yml configuration
echo "11. Checking docker-compose.yml key settings..."
echo "shm_size:"
grep "shm_size:" docker-compose.yml 2>/dev/null
echo "links:"
grep -A2 "links:" docker-compose.yml 2>/dev/null || echo "  NOT configured (may cause DNS issues)"
echo "ZM_PATH_ZMS env:"
grep "ZM_PATH_ZMS" docker-compose.yml 2>/dev/null || echo "  NOT configured"
echo ""

# Network connectivity test
echo "12. Testing container-to-container network..."
docker exec zoneminder ping -c 2 mysql 2>/dev/null | grep "bytes from" || echo -e "${RED}✗ Cannot ping mysql container${NC}"
echo ""

echo "========================================="
echo "Diagnostic complete!"
echo "========================================="