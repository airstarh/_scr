#!/bin/bash

echo "=== Complete ZoneMinder Reset ==="

# Stop and remove everything
docker compose down -v
docker rm -f zoneminder 2>/dev/null || true

# Remove the problematic mysql directory
sudo rm -rf ./data/mysql

# Remove the named volume if it exists
docker volume rm vzm_zm_mysql_data 2>/dev/null || true
docker volume rm zm_mysql_data 2>/dev/null || true

# Clean up any remaining locks
sudo rm -rf ./data/.mysql_lock 2>/dev/null || true

# Create fresh directories (excluding mysql since we use named volume)
mkdir -p ./data/events ./data/images ./data/logs

# Set permissions
sudo chown -R 1000:1000 ./data
chmod 755 ./data ./data/events ./data/images ./data/logs

# Start fresh
docker compose up -d

echo "Waiting 90 seconds for MySQL to initialize..."
sleep 90

echo "Checking logs..."
docker compose logs --tail=30

echo ""
echo "Access ZoneMinder at: http://localhost:8080/zm/"