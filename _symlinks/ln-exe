#!/bin/bash
cd /osa/home/qqq/qemu

qemu-system-x86_64 \
  -machine pc \
  -cpu qemu64 \
  -smp 1 \
  -m 2048 \
  -drive file=w7x64_HDA.img,format=qcow2,if=ide \
  -boot order=c \
  -vga std \
  -display gtk \
  -usb \
  -device usb-tablet \
  -rtc base=localtime \
  -audiodev pa,id=snd \
  -device ac97,audiodev=snd