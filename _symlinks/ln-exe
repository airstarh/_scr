#!/bin/bash

# Find all files and directories up to level 4
find . -maxdepth 4 -type d -printf "%d\t%p\n" 2>/dev/null | \
sort -n | \
while IFS=$'\t' read -r depth path; do
    # Calculate the number of spaces for indentation (2 spaces per level)
    indent=$((depth * 2))
    # Print the directory name with indentation
    printf "%*s%s\n" $indent "" "${path##*/}/"

    # For each directory, list its immediate files (only if we're not at level 4)
    if [ $depth -lt 4 ]; then
        find "$path" -maxdepth 1 -type f -printf "  %s\n" 2>/dev/null | sort | \
        while read -r file; do
            printf "%*s%s\n" $((indent + 2)) "" "$file"
        done
    fi
done
