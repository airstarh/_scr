#!/bin/bash

# ============================================
# Complete VirtualBox Nuclear Removal Script
# Removes ALL traces of VirtualBox from system
# ============================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_status() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1"; }

echo "=========================================="
echo "VirtualBox Complete Nuclear Removal"
echo "=========================================="
echo ""

# Check if running with sudo
if [[ $EUID -ne 0 ]]; then
    print_error "This script must be run with sudo!"
    echo "Please run: sudo $0"
    exit 1
fi

# Get the real user (not root)
REAL_USER=${SUDO_USER:-$USER}
REAL_HOME=$(getent passwd $REAL_USER | cut -d: -f6)

print_status "Removing VirtualBox for user: $REAL_USER"

# ============================================
# 1. Stop all VirtualBox processes
# ============================================
print_status "Stopping all VirtualBox processes..."
killall VirtualBox VBoxSVC virtualbox 2>/dev/null
pkill -f VBoxSVC 2>/dev/null
pkill -f VirtualBox 2>/dev/null
pkill -f "VBox*" 2>/dev/null
sleep 3
print_success "All processes stopped"

# ============================================
# 2. Unregister and delete all VMs
# ============================================
print_status "Removing all virtual machines..."
VBoxManage list vms 2>/dev/null | cut -d '"' -f2 | while read vm; do
    print_status "  - Unregistering and deleting: $vm"
    VBoxManage unregistervm "$vm" --delete 2>/dev/null
done

# ============================================
# 3. Remove VirtualBox packages
# ============================================
print_status "Removing VirtualBox packages..."

# Remove main packages
apt remove --purge -y \
    virtualbox \
    virtualbox-* \
    virtualbox-dkms \
    virtualbox-ext-pack \
    virtualbox-guest-additions-iso \
    virtualbox-qt \
    2>/dev/null

# Remove any orphaned packages
apt autoremove --purge -y 2>/dev/null

# Remove any VirtualBox-related packages
dpkg -l | grep -i virtualbox | awk '{print $2}' | xargs -r dpkg --purge 2>/dev/null

print_success "Packages removed"

# ============================================
# 4. Remove VirtualBox kernel modules
# ============================================
print_status "Removing VirtualBox kernel modules..."
modprobe -r vboxdrv vboxnetadp vboxnetflt vboxpci 2>/dev/null

# Remove module files
rm -f /lib/modules/*/misc/vbox*.ko 2>/dev/null
rm -f /lib/modules/*/updates/dkms/vbox*.ko 2>/dev/null

# Update module dependencies
depmod -a 2>/dev/null
print_success "Kernel modules removed"

# ============================================
# 5. Remove DKMS sources
# ============================================
print_status "Removing DKMS sources..."
rm -rf /var/lib/dkms/vboxhost 2>/dev/null
rm -rf /var/lib/dkms/virtualbox* 2>/dev/null
rm -rf /usr/src/vboxhost-* 2>/dev/null
rm -rf /usr/src/virtualbox-* 2>/dev/null
print_success "DKMS sources removed"

# ============================================
# 6. Remove configuration files
# ============================================
print_status "Removing configuration files..."

# System-wide configs
rm -rf /etc/vbox 2>/dev/null
rm -f /etc/apt/sources.list.d/virtualbox.list 2>/dev/null
rm -f /etc/apt/sources.list.d/oracle-vbox.list 2>/dev/null

# User configs
rm -rf $REAL_HOME/.config/VirtualBox 2>/dev/null
rm -rf $REAL_HOME/.VirtualBox 2>/dev/null
rm -rf $REAL_HOME/.local/share/VirtualBox 2>/dev/null
rm -rf $REAL_HOME/.vbox* 2>/dev/null

# Global VirtualBox directory
rm -rf /opt/VBoxGuestAdditions-* 2>/dev/null
rm -rf /usr/lib/virtualbox 2>/dev/null

# Remove VBoxSVC files
rm -rf /tmp/.vbox-* 2>/dev/null
rm -rf /tmp/vbox-* 2>/dev/null

print_success "Configuration files removed"

# ============================================
# 7. Remove user groups and permissions
# ============================================
print_status "Removing user from vboxusers group..."
deluser $REAL_USER vboxusers 2>/dev/null

# Remove the group if empty
groupdel vboxusers 2>/dev/null
print_success "Groups cleaned"

# ============================================
# 8. Clean package cache
# ============================================
print_status "Cleaning package cache..."
apt clean 2>/dev/null
apt autoclean 2>/dev/null
print_success "Package cache cleaned"

# ============================================
# 9. Remove leftover files
# ============================================
print_status "Removing leftover files..."

# Find and remove any VirtualBox files (excluding your VM images if you want to keep them)
find /usr -name "*vbox*" -type f 2>/dev/null | grep -v "vboxvideo" | xargs -r rm -f 2>/dev/null
find /etc -name "*vbox*" -type f 2>/dev/null | xargs -r rm -f 2>/dev/null
find /var -name "*vbox*" -type f 2>/dev/null | xargs -r rm -f 2>/dev/null

# Remove desktop files
rm -f /usr/share/applications/virtualbox*.desktop 2>/dev/null
rm -f /usr/share/applications/org.virtualbox.*.desktop 2>/dev/null
rm -f /usr/share/icons/hicolor/*/apps/virtualbox* 2>/dev/null

# Remove documentation
rm -rf /usr/share/doc/virtualbox* 2>/dev/null
rm -rf /usr/share/doc/VBoxGuestAdditions* 2>/dev/null

print_success "Leftover files removed"

# ============================================
# 10. Remove KVM blacklist (clean up after ourselves)
# ============================================
print_status "Removing KVM blacklist (restoring KVM if desired)..."
rm -f /etc/modprobe.d/blacklist-kvm.conf 2>/dev/null
rm -f /etc/modprobe.d/virtualbox-fix.conf 2>/dev/null
rm -f /etc/modprobe.d/virtualbox.conf 2>/dev/null
update-initramfs -u 2>/dev/null
print_success "Cleanup complete"

# ============================================
# 11. Verification
# ============================================
echo ""
print_status "Verifying removal..."

# Check if any VirtualBox packages remain
REMAINING=$(dpkg -l | grep -i virtualbox | wc -l)
if [ $REMAINING -eq 0 ]; then
    print_success "No VirtualBox packages remain"
else
    print_warning "Some packages may still remain:"
    dpkg -l | grep -i virtualbox
fi

# Check if VBoxManage exists
if command -v VBoxManage &>/dev/null; then
    print_error "VBoxManage still found in PATH"
else
    print_success "VBoxManage not found - good"
fi

# Check for kernel modules
if lsmod | grep -q vbox; then
    print_warning "Some vbox modules are still loaded"
    lsmod | grep vbox
else
    print_success "No vbox modules loaded"
fi

echo ""
print_success "=========================================="
print_success "VirtualBox has been COMPLETELY removed!"
print_success "=========================================="
echo ""

# Ask about removing VM files
print_warning "Your VM disk files (VDI/VMDK) are still in /osa/_vbx/ if you want to keep them"
read -p "Do you want to DELETE all VM disk files? (y/n): " -n 1 -r
echo ""
if [[ $REPLY =~ ^[Yy]$ ]]; then
    print_status "Deleting VM files..."
    rm -rf /osa/_vbx 2>/dev/null
    rm -rf /ose/_vbx 2>/dev/null
    rm -rf $REAL_HOME/VirtualBox\ VMs 2>/dev/null
    print_success "VM files deleted"
else
    print_status "Keeping VM files at /osa/_vbx/"
    print_status "You can delete them manually later if desired"
fi

echo ""
print_status "A reboot is recommended to complete cleanup"
read -p "Reboot now? (y/n): " -n 1 -r
echo ""
if [[ $REPLY =~ ^[Yy]$ ]]; then
    print_status "Rebooting in 5 seconds..."
    sleep 5
    reboot
else
    print_warning "Please reboot later to complete cleanup: sudo reboot"
fi#!/bin/bash

